ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get this from: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Permissions needed: Contents (read), Issues (write), Pull requests (write)
GITHUB_TOKEN=ghp_your-token-here

# Secret for verifying GitHub webhooks (make up any random string)
GITHUB_WEBHOOK_SECRET=myapp2024secret

# Leave these as-is for local development
CHROMA_PATH=./chroma_db
APP_PORT=8000
